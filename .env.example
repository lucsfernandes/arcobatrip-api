# Porta da aplicação
PORT=3000

# Configurações do banco de dados PostgreSQL
TYPEORM_HOST=localhost
TYPEORM_PORT=5432
TYPEORM_USERNAME=postgres
TYPEORM_PASSWORD=sua_senha
TYPEORM_DATABASE=arcobatrip
TYPEORM_SYNC=false

API_BASE_URL=
WEB_BASE_URL=
JWT_SECRET=

# Envio de emails transacionais (Resend - https://resend.com)
# Deixe RESEND_API_KEY vazio para desabilitar o envio (a aplicação apenas loga um aviso).
RESEND_API_KEY=
# EMAIL_FROM=Arcobatrip <no-reply@arcobatrip.com>

# URL base do frontend, usada para montar os links de reset/confirmação de email
# APP_URL=http://localhost:5173

# Tempo de vida (em minutos) dos tokens enviados por email
# EMAIL_VERIFICATION_TOKEN_TTL_MIN=1440
# PASSWORD_RESET_TOKEN_TTL_MIN=60